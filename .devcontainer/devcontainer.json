{
  "name": "RAIR-VF GPU",
  "dockerComposeFile": "docker-compose.yml",
  "service": "rair-vf",
  "workspaceFolder": "/workspace/app",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.analysis.extraPaths": [
          "/workspace/app"
        ]
      }
    }
  },
  "postCreateCommand": "python3 -c \"import torch; print('cuda:', torch.cuda.is_available()); print(torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'cpu')\""
}
